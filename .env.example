# =============================================================================
# Pivo — environment overrides
# =============================================================================
# Copy this file to `.env` and adjust as needed:
#   cp .env.example .env
#
# Only TZ and ADMIN_PASSWORD are read by docker-compose.
# PORT and DATA_DIR are baked into the image and don't need to be set here.
# =============================================================================

# Timezone the cron scheduler interprets (any IANA tz name).
TZ=America/New_York

# Optional admin password. If set, the UI is gated by HTTP basic auth
# (username = admin). The /unsubscribe route stays public regardless.
#
# Leave this blank if any of the following is true:
#   - Running on a trusted LAN with no public exposure
#   - Fronted by Cloudflare Access / Tailscale / Authelia / another auth proxy
#   - You want to handle auth at your reverse proxy instead
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Local development only (running `npm run dev` outside Docker)
# -----------------------------------------------------------------------------
# PORT=1998
# DATA_DIR=./data
