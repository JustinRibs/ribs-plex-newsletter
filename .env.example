# Port the web UI listens on
PORT=3000

# Where SQLite + uploads live (inside the container this is /data; on the host, mount a volume here)
DATA_DIR=./data

# Optional admin password. If set, the UI is protected by HTTP basic auth (username = admin).
# Leave blank for no auth (only do this on a trusted network).
ADMIN_PASSWORD=

# Timezone used for scheduling cron jobs. Must be a valid IANA tz (e.g. "America/New_York").
TZ=America/New_York
